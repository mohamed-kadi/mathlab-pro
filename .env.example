# Server runtime
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
MATHLAB_DB_FILE="./data/db.json"

# PostgreSQL runtime and migration target. If DATABASE_URL is set, the server
# uses PostgreSQL repositories. Leave it unset to use the JSON fallback.
POSTGRES_DB="mathlab_pro"
POSTGRES_USER="mathlab"
POSTGRES_PASSWORD="mathlab_dev_password"
# DATABASE_URL="postgres://mathlab:mathlab_dev_password@localhost:5432/mathlab_pro"

# Calculation cache. Leave REDIS_URL unset to use the in-process cache.
# REDIS_URL="redis://localhost:6379"
CALCULATION_CACHE_TTL_SECONDS="900"

# Optional: enables the AI tutoring endpoint.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Public URL used by deployment environments and future callback links.
APP_URL="http://localhost:3000"
