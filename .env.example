# Server runtime
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Optional: enables the AI tutoring endpoint.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Public URL used by deployment environments and future callback links.
APP_URL="http://localhost:3000"
