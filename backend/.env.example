# Spring Boot backend runtime
# Copy values into your shell, Docker environment, or an untracked backend/.env file.
# Spring Boot does not automatically load this file when running Maven directly.
PORT=8080

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/mathlab_pro
SPRING_DATASOURCE_USERNAME=mathlab
SPRING_DATASOURCE_PASSWORD=mathlab_dev_password

# Redis
REDIS_URL=redis://localhost:6379
CALCULATION_CACHE_TTL_SECONDS=900
CALCULATION_CACHE_MAX_ENTRIES=1000

# Security
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional AI tutoring provider
AI_PROVIDER_BASE_URL=
AI_PROVIDER_API_KEY=
AI_PROVIDER_MODEL=
